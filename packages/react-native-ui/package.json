{
  "name": "@dotnaos/react-native-ui",
  "version": "0.0.1",
  "description": "Minimal React Native UI primitives aligned with the DotNaos design system.",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "pnpm run clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "dependencies": {
    "@dotnaos/design-system": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.1.13",
    "react-native": "^0.85.2",
    "typescript": "^5.9.2"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-native": ">=0.74"
  }
}
