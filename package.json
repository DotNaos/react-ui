{
  "name": "@dotnaos/react-ui",
  "version": "0.0.1",
  "description": "Shared React UI primitives, components, and design tokens for DotNaos projects.",
  "private": false,
  "type": "module",
  "packageManager": "pnpm@10.11.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/DotNaos/react-ui.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "files": [
    "dist",
    "tailwind.config.ts",
    "components.json",
    "README.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "pnpm run clean && tsc -p tsconfig.build.json && pnpm run copy:css",
    "clean": "rm -rf dist",
    "copy:css": "copyfiles -u 1 \"src/**/*.css\" dist",
    "typecheck": "tsc --noEmit",
    "ui:add": "bunx shadcn@latest add",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./tailwind.config": {
      "types": "./tailwind.config.ts",
      "default": "./tailwind.config.ts"
    },
    "./lib/utils": {
      "types": "./dist/lib/utils.d.ts",
      "import": "./dist/lib/utils.js",
      "default": "./dist/lib/utils.js"
    },
    "./tokens.css": {
      "default": "./dist/tokens.css"
    },
    "./tailwind-theme.css": {
      "default": "./dist/tailwind-theme.css"
    },
    "./styles.css": {
      "default": "./dist/styles.css"
    }
  },
  "dependencies": {
    "@heroui/react": "^3.0.2",
    "@heroui/styles": "^3.0.2",
    "@radix-ui/react-accordion": "^1.2.1",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-symbols/icons": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.562.0",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@tailwindcss/vite": "^4.1.14",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "copyfiles": "^2.4.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "storybook": "^10.3.5",
    "tailwindcss": "^4.1.14",
    "typescript": "^5.9.2",
    "vite": "^7.1.10"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  }
}
